{
  "compilerOptions": {
    "module":           "commonjs",
    "moduleResolution": "node",
    "noImplicitAny":    true,
    "noImplicitReturns": true,
    "strictNullChecks": true,
    "outDir":           "lib",
    "rootDir":          "src",
    "strict":           true,
    "target":           "ES2020",
    "skipLibCheck":     true,
    "esModuleInterop":  true,
    "resolveJsonModule": true
  },
  "compileOnSave": true,
  "include": ["src"],
  "exclude": ["node_modules"]
}
