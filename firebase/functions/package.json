    "firebase-functions": "^4.9.0"
  },
  "devDependencies": {
    "typescript":       "^5.4.5",
    "@types/node":      "^20.12.7",
    "firebase-functions-test": "^3.3.0",
    "eslint":           "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^7.8.0",
    "@typescript-eslint/parser":        "^7.8.0"
  }
}
