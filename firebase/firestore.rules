rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return request.auth.uid == uid;
    }
    function hasNoSensitiveFields() {
      let sensitive = ['_accessToken', '_metaLongLivedToken', 'tokenExpiresAt'];
      return !request.resource.data.keys().hasAny(sensitive);
    }

    match /users/{uid} {
      allow read, update: if isAuth() && isOwner(uid);
      allow create: if isAuth() && isOwner(uid);

      match /posts/{postId} {
        allow read: if true;
        allow write: if isAuth() && isOwner(uid);
      }

      match /planning/{planId} {
        allow read: if true;
        allow write: if isAuth() && isOwner(uid);
      }
    }

    match /socialAccounts/{accountId} {
      allow read, update: if isAuth() && isOwner(uid);
      allow create, update: if isAuth() && isOwner(uid) && hasNoSensitiveFields();
      allow delete: if isAuth() && isOwner(uid);
    }

    match /posts/{postId} {
      allow read, write: if isAuth();
    }

    match /agendamentos/{docId} {
      allow read, write: if isAuth();
    }

    match /agendamentos/{docId}/{subcollection=**} {
      allow read, write: if isAuth();
    }

    match /notifications/{notifId} {
      allow read: if isAuth() && isOwner(uid);
      allow write: if false;
    }

    // Colab
    match /colab_invites/{docId} {
      allow read: if true;
      allow create: if isAuth();
      allow update: if true;
    }

    match /colab_posts/{docId} {
      allow read: if true;
      allow write: if isAuth();
    }

    match /colab_planning/{docId} {
      allow read: if true;
      allow write: if isAuth();
    }

    match /colab_ratings/{docId} {
      allow read: if isAuth();
      allow create: if true;
    }

    match /posts/{postId} {
      allow read: if true;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
